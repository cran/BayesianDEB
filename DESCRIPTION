Package: BayesianDEB
Title: Bayesian Dynamic Energy Budget Modelling
Version: 0.2.1
Date: 2026-06-17
Authors@R: c(
    person("Branimir K.", "Hackenberger",
           email = "branimir@sciom.hr",
